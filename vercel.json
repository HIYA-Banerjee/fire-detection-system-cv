{
  "version": 2,
  "buildCommand": "cd agniv-2.0/frontend && npm install && npm run build",
  "outputDirectory": "agniv-2.0/frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://fire-detection-backend-c1xy.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
